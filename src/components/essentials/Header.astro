---
import SocialLinks from "./SocialLinks.astro"
import DropdownMenu from "./DropdownMenu.astro";
const { backgroundColor } = Astro.props;

const headerStyle = backgroundColor
  ? `background-color: ${backgroundColor};`
  : `background-color: var(--cream);`;
---

<header style={headerStyle}>
    <div class="social-links-container">
        <div class=>
            <!-- <a href="#" id="newsletter">ZAPISZ SIĘ DO NASZEGO NEWSLETTERA</a> -->
        </div>
        <div>
            <SocialLinks />
        </div>
    </div>

    <div class="text">
        <nav>
            <a href="/"><div class="logo-div item1">
                <img class="logo" src="/images/meta/logo.png" alt="Logo Fundacji Chatka Gołębia."/>
            </div></a>
            <div class="links">
                <div class="buttons">
                    <a class="button button-peach" href='/znalazlem-golebia'>ZNALAZŁEM GOŁĘBIA</a>
                    <a class="button button-grass" href='/wspomoz-nas'>WSPOMÓŻ NAS</a>
                </div>
                <button id="nav-toggle" class="nav-button"><svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 15 15"><path fill="currentColor" fill-rule="evenodd" d="M1.5 3a.5.5 0 0 0 0 1h12a.5.5 0 0 0 0-1zM1 7.5a.5.5 0 0 1 .5-.5h12a.5.5 0 0 1 0 1h-12a.5.5 0 0 1-.5-.5m0 4a.5.5 0 0 1 .5-.5h12a.5.5 0 0 1 0 1h-12a.5.5 0 0 1-.5-.5" clip-rule="evenodd"/></svg></button>
                
                <div id="nav-menu" class="nav-menu">
                    <ul class="nav-list">
                        <li class="mobile-only"><a class="button button-peach" href='/znalazlem-golebia'>ZNALAZŁEM GOŁĘBIA</a></li>
                        <li class="mobile-only"><a class="button button-grass" href='/wspomoz-nas'>WSPOMÓŻ NAS</a></li>
                        <li><a href="/o-nas">O nas</a></li>
                        <li><a href="/adopcja">Adopcja</a></li>
                        <li><a href="/golebie-z-chatki">Gołębie z Chatki</a></li>
                        <li>
                            <DropdownMenu 
                                label="Co robimy"
                                items={[
                                    { label: "Co nowego", href: "/aktualnosci" },
                                    { label: "Zrealizowane wydarzenia", href: "/wydarzenia" },
                                    { label: "Interwencje", href: "/interwencje" },
                                    { label: "Podsumowania miesiąca", href: "/podsumowania-miesiaca" },
                                ]}
                            />
                        </li>
                        <li><a href="/poradniki">Baza wiedzy o gołębiach (Poradniki)</a></li>
                        <li><a href="/kampanie/akcja-sznurek">Akcja Sznurek</a></li>
                        <!-- <li><a href="/kalkulator-dawek">Kalkulator dawek</a></li> -->
                        <!-- <li><a href="/atlas-gołębi">Atlas gołębi</a></li> -->
                        <li><a href="/sponsorzy">Partnerzy</a></li>
                        <li><a href="/media-o-nas">Media</a></li>
                        <!-- <li><a href="/szablony">Szablony</a></li> -->
                        <li><a href="/kontakt">Kontakt</a></li>         
                    </ul>
                </div>
            </div>
            </div>
        </nav>
    </div>
</header>

<style>

header {
    background-image: url('/images/meta/header/background-top-mobile.svg');
    background-repeat: no-repeat;
    background-position: 50% 102%;
    background-size: cover;
}

a {
    font-weight: 700;
}

.social-links-container {
    display: flex;
    justify-content: flex-end;
    gap: 3em;
    align-items: center;
    padding-inline: 5%;
    background-color: var(--lavender);
}

.buttons {
    display: none;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5em;
}

.button {
    color: black;
    padding: 10px;
    font-size: 2rem;
}

.links {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5em;
}

.links a {
    font-family: 'Ubuntu Condensed';
    color: var(--plum);
}

.nav-menu {
    font-family: "Ubuntu Condensed";
    position: absolute; 
    left: 0;
    background-color: var(--cream);
    width: 100%;
    pointer-events: none;
    overflow: auto;
    display: grid; 
    grid-template-rows: 0fr;
    transition: 0.3s grid-template-rows ease;
    top: 14rem;
    box-shadow: 0 10px 10px rgba(0, 0, 0, 0.2);
}

.show-menu {
    grid-template-rows: 1fr;
    pointer-events: initial;
    padding-block: 0.4rem;
    }

.nav-menu a {
    text-align: center;
    font-size: 2rem;
}

.nav-menu a:hover {
    color: var(--peach);
}

.logo {
    max-width: 120px;
    width: auto;
}

.logo-div {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5em;
}

nav {
    flex-direction: row;
    padding-inline: 2%;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 1.5em;
}

.nav-list {
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.nav-list a {
    display: block;
    width: 100%;
    padding: 1rem;
}

    .nav-button {
        border: none;
        background-color: rgba(255, 255, 255, 0);
        color: var(--plum);
        position: relative;
        z-index: 100;
    }


@media (max-width: 759px) {
    .mobile-only {
        display: list-item;
        padding: 0.6rem;
    }

    .mobile-only a {
        display: block;
        width: 80%;
        margin-inline: auto;
        text-align: center;
        font-size: 2rem;
    }
}

/* Larger screens (e.g., tablets) */
@media (min-width: 468px) {

    nav {
        padding-block: 2rem 3rem;
        position: relative;
    }

    .buttons {
        position: absolute;;
        display: flex;
        flex-direction: column;
        gap: 1em;
        top: 15%;
        left: 41%;
    }
    nav {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        padding-inline: 6%;
        gap: 20px;
    }


    .links {
        flex-direction: row;
        gap: 1em;
       
    }

    .nav-menu {
        top: 13rem;
    }

.mobile-only {
    display: none;
}
}

@media (min-width: 760px) {
    header {
        padding-bottom: 180px;
        background-image: url('/images/meta/header/background-top.svg');
        box-shadow: 0 0 0;
    }

    .social-links-container {
        padding-inline: 70px;
    }

    .nav-list a {
        padding: 6px 0;
    }

  nav {
    position: static;
    padding-block: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .links {
    align-items: center;
    flex-direction: column;
    gap: 34px;
  }

  .buttons {
    position: static;
    flex-direction: row;
  }

    .logo {
        max-width: 244px; 
        
    }

    .button {
        font-size: 2.2rem;
        padding: 18px;
    }

    .nav-menu {
        font-family: "Ubuntu Condensed";
        display: flex;
        opacity: 1;
        position: static;
        padding-inline: 0;
        box-shadow: 0 0 0;
        background-color: rgba(255, 255, 255, 0);
        pointer-events: all;
}

.nav-menu a {
    font-size: 2rem;
}


.nav-list {
    display: flex;
    justify-content: space-between;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 1.5rem;
}

.nav-button {
    display: none;
}
}

/* Larger screens (e.g., desktops) */
@media (min-width: 1500px) {
    nav {
        padding-inline: calc(6vw + 0.1rem);
        padding-top: 60px;
        margin-inline: auto;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        max-width: 1920px;
        background: 70% 50% no-repeat url("/images/index/wave-copy.png");
    }

    header {
        padding-bottom: 160px;
    }

    .buttons {
        margin-left: auto;
        gap: 34px;
    }


    .logo-div {
        flex-direction: row; /* Row layout for desktop */
        gap: 2em;
    }

    .logo {
        position: absolute;
        top: 100px;
        max-width: 340px;
}
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav-menu');

  if (toggle && nav) {
    let isOpen = false;

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen = !isOpen;
      nav.classList.toggle('show-menu', isOpen);
      toggle.classList.toggle('show-icon', isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!isOpen) return;
      const target = e.target as Node;
      if (toggle.contains(target) || nav.contains(target)) return;
      isOpen = false;
      nav.classList.remove('show-menu');
      toggle.classList.remove('show-icon');
    });
  }
});
</script>
