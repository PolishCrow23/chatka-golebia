---
import SectionWrapper from "../SectionWrapper.astro";
---

<SectionWrapper maxWidth="900px" padding="2rem 1rem" noGrid backgroundColor="linear-gradient(to right, var(--lavender) 50%, var(--peach) 50%)">
    <div class="container">
        <img src="/images/index/found-pigeon.png" alt="" class="bg-image" />
        <div class="content">
            <h2>Znalazłeś/aś gołębia?</h2>
            <p class="subtitle">Jeśli widzisz któreś z tych sygnałów, gołąb może potrzebować twojej pomocy</p>
            <ul>
                <li>Siedzi bez ruchu na ziemi</li>
                <li>Ma przymknięte oczy</li>
                <li>Ma owinięte wokół łapek sznurki</li>
                <li>Opada mu skrzydło</li>
                <li>Jest bardzo młody (pisklę lub podlot)</li>
                <li>Jest gołębiem domowym (np. ozdobny, z obrączką)</li>
            </ul>
            <a class="button button-peach" href="/znalazlem-golebia">
                DOWIEDZ SIĘ JAK POMÓC GOŁĘBIOWI
            </a>
        </div>
    </div>
</SectionWrapper>

<style>
    .container {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 3rem 2%;
        background-color: white;
        border-radius: 35px;
    }

    .bg-image {
        display: none;
    }

    .content {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }

    h2 {
        font-family: "Ubuntu Condensed";
        font-size: 4rem;
        font-weight: 700;
        color: var(--plum);
        margin: 0 0 0.4em;
    }

    .subtitle {
        font-family: "Inter", sans-serif;
        font-size: 1.8rem;
        color: var(--plum);
        margin-bottom: 0.8em;
        line-height: 1.5;
    }

    ul {
        list-style: disc;
        padding-left: 2.2rem;
        margin-bottom: 1.2rem;
        display: inline-block;
        text-align: left;
    }

    li {
        font-family: "Inter", sans-serif;
        font-size: 1.8rem;
        color: var(--plum);
        line-height: 1.6;
    }

    .button { display: inline-block; }

    @media(min-width: 768px) {

    }
</style>
