---
interface Props {
    title?: string;
    description?: string;
    showMoreText?: string;
    showMoreHref?: string;
    showMoreVariant?: string;
    backgroundColor?: string;
    maxWidth?: string;
    titlePaddingLeft?: string;
    padding?: string;
    noGrid?: boolean;
}

const { 
    title,
    description,
    showMoreText, 
    showMoreHref,
    showMoreVariant = 'button-grass',
    backgroundColor = "transparent",
    maxWidth = "1500px",
    titlePaddingLeft = "0",
    padding,
    noGrid = false
} = Astro.props;
---

<section style={`background: ${backgroundColor};${padding ? ` padding: ${padding};` : ''}`}>
    <div class="wrapper">
        {title && <h2 style={`padding-left: ${titlePaddingLeft};`}>{title}</h2>}
        {description && <p class="section-description">{description}</p>}
        
        <!-- Check if there's custom content slot, otherwise use default grid -->
        <slot name="content">
            <div class={noGrid ? '' : 'content-grid'} style={`max-width: ${maxWidth}; margin-inline: auto;`}>
                <slot />
                {showMoreText && showMoreHref && (
                    <a href={showMoreHref} class={`button ${showMoreVariant} show-more`}>
                        {showMoreText}
                    </a>
                )}
            </div>
        </slot>
    </div>
</section>

<style>
    section {
        padding-inline: 2%;
        padding-block: 1rem;
    }

    .wrapper {
        max-width: 1920px;
        margin-inline: auto;
    }

    h2 {
        font-family: "Urbanist", sans-serif;
        font-weight: 900;
        font-size: 5rem;
        color: var(--plum);
        display: block;
        padding-bottom: 2rem;
        margin: 0;
    }

    .section-description {
        font-family: "Inter", sans-serif;
        font-size: 2rem;
        color: var(--plum);
        padding-bottom: 4rem;
        margin: 0;
    }

    .content-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: flex-start;
        gap: 3rem;
        margin-inline: auto;
        padding-bottom: 3rem;
    }

    .show-more {
        display: block;
        width: fit-content;
        margin-inline: auto;
        font-size: 1.8rem;
        text-align: center;
    }

        @media (min-width: 758px) {
            .show-more {
                margin: 2rem 0 0 auto;
                font-size: 2.1rem;
            }
        }

    @media (max-width: 758px) {
        h2 {
            font-size: 4.1rem;
            padding-left: 0 !important;
            text-align: center;
        }

        .content-grid {
            flex-direction: column;
            align-items: center;
        }

        .show-more {
            justify-content: center;
        }
    }

    @media (max-width: 900px) {
        section {
            padding-block: 2rem 3rem;
        }

        .wrapper {
            padding-inline: 2%;
        }

        
    .section-description {
        padding-left: 0;
        padding-bottom: 2rem;
        margin: 0;
    }
    }
</style>